@startuml SmartLocateSG_DesignClassDiagram_Master
left to right direction
skinparam classAttributeIconSize 0
skinparam linetype ortho

package "Boundary" {
  class AppStartup <<boundary>> {
    +bootstrap(): void
  }
  class AuthUI <<boundary>> {
    +register(): void
    +login(): void
    +logout(): void
  }
  class ProfilesUI <<boundary>> {
    +createProfile(): void
    +editProfile(): void
    +deleteProfile(): void
    +setActiveProfile(): void
  }
  class MapUI <<boundary>> {
    +toggleOverlay(): void
    +toggleLayer(): void
    +dropPin(): void
    +requestScore(): void
    +openWeightPanel(): void
    +saveToPortfolio(): void
  }
  class PortfolioUI <<boundary>> {
    +listSites(): void
    +editNotes(): void
    +deleteSite(): void
  }
  class CompareUI <<boundary>> {
    +selectSites(): void
    +compare(): void
    +exportPdf(): void
  }
  class AdminUI <<boundary>> {
    +viewDataStatus(): void
    +runRefresh(): void
    +manageConfig(): void
  }
}

package "Control" {
  class AuthController <<control>> {
    +register(request: HttpRequest): HttpResponse
    +login(request: HttpRequest): HttpResponse
    +logout(request: HttpRequest): HttpResponse
    +refreshSession(request: HttpRequest): HttpResponse
    +getCurrentUser(request: HttpRequest): HttpResponse
  }
  class ProfileController <<control>> {
    +listProfiles(userId: string): List<BusinessProfile>
    +createProfile(input: CreateBusinessProfileInput): BusinessProfile
    +updateProfile(profileId: string, userId: string, input: UpdateBusinessProfileInput): BusinessProfile
    +deleteProfile(profileId: string, userId: string): void
    +setActiveProfile(profileId: string, userId: string): void
  }
  class MapController <<control>> {
    +getPlanningAreaOverlays(metric: OverlayMetric): GeoJsonFeatureCollection
    +getPointLayer(layer: LayerKey, focus: RadiusFilter): PointLayerCollection
    +scoreSite(input: SiteScoreRequest): SiteScore
  }
  class ScoringController <<control>> {
    +scoreSiteLocation(input: SiteScoreRequest): SiteScore
    +computeComposite(scores: Map<String, number>, weights: WeightConfig): number
    +generateScoreBreakdown(siteScore: SiteScore): Map<String, number>
  }
  class PortfolioController <<control>> {
    +listSites(userId: string): List<CandidateSite>
    +saveSite(input: SaveCandidateSiteInput): CandidateSite
    +deleteSite(siteId: string, userId: string): void
    +updateSiteNotes(siteId: string, userId: string, notes: string): CandidateSite
  }
  class CompareController <<control>> {
    +selectSites(siteIds: List<string>): ComparisonSet
    +compareSites(siteIds: List<string>): ComparisonResult
    +exportPdf(siteIds: List<string>): Binary
  }
  class AdminController <<control>> {
    +viewDataStatus(): DataStatus
    +runRefresh(): void
    +manageConfig(config: WeightConfig): WeightConfig
  }
  class ExplanationController <<control>> {
    +explainScore(payload: ExplainScoreRequest): Explanation
    +saveFeedback(payload: ExplanationFeedbackInput): ExplanationFeedback
  }
  class ChatbotController <<control>> {
    +generateResponse(payload: ChatbotRequest): ChatbotReply
    +buildContext(payload: ChatbotRequest): string
  }

  class ScoreEngine <<control>> {
    +computeComposite(): number
    +computeDimensionScores(): Map<String, number>
  }

  class ETLCoordinator <<control>> {
    +refreshDataSources(): void
    +updateAreaProfiles(): void
  }
}

package "Entity" {
  class User <<entity>> {
    +id: string
    +username: string
    +passwordHash: string
  }

  class BusinessProfile <<entity>> {
    +id: string
    +userId: string
    +businessName: string
    +sector: string
    +priceBand: string
    +targetAgeGroupsJson: json
    +targetIncomeBandsJson: json
    +operatingModel: string
    +isActive: int
  }

  class CandidateSite <<entity>> {
    +id: string
    +userId: string
    +profileId: string
    +siteName: string
    +lat: number
    +lng: number
    +planningAreaId: string
    +savedSiteScoreId: string
    +notes: text
  }

  class SiteScore <<entity>> {
    +id: string
    +compositeScore: number
    +demographicScore: number
    +accessibilityScore: number
    +rentalPressureScore: number
    +competitionScore: number
    +breakdownDetailsJson: json
    +computedAt: datetime
  }

  class PlanningArea <<entity>> {
    +id: string
    +areaName: string
    +areaCode: string
    +regionName: string
    +geometryGeojson: text
  }

  class AreaDemographics <<entity>> {
    +id: string
    +planningAreaId: string
    +effectiveYear: int
    +populationTotal: int
    +ageDistributionJson: json
    +incomeDistributionJson: json
  }

  class ExplanationFeedback <<entity>> {
    +page: string
    +profileId: string
    +siteId: string
    +criterion: string
    +vote: string
  }

  class WeightConfig <<entity>> {
    +profileId: string
    +demographicWeight: int
    +accessibilityWeight: int
    +rentalWeight: int
    +competitionWeight: int
  }
}

package "Persistence" {
  class UserRepository <<repository>> {
    +getUser(id: string): User
    +getUserByUsername(username: string): User
    +createUser(user: InsertUser): User
  }
  class ProfileRepository <<repository>> {
    +getBusinessProfiles(userId: string): List<BusinessProfile>
    +createBusinessProfile(input: CreateBusinessProfileInput): BusinessProfile
    +updateBusinessProfile(profileId: string, userId: string, input: UpdateBusinessProfileInput): BusinessProfile
    +deleteBusinessProfile(profileId: string, userId: string): void
    +setActiveBusinessProfile(profileId: string, userId: string): void
  }
  class SiteRepository <<repository>> {
    +getCandidateSites(userId: string): List<CandidateSite>
    +saveCandidateSite(input: SaveCandidateSiteInput): CandidateSite
    +deleteCandidateSite(siteId: string, userId: string): void
  }
  class ScoreRepository <<repository>> {
    +createSiteScore(input: SiteScore): SiteScore
    +getSiteScoreById(siteScoreId: string): SiteScore
    +deleteSiteScore(siteScoreId: string): void
  }
  class PlanningAreaRepository <<repository>> {
    +getPlanningAreaOverlayCollection(metric: OverlayMetric): GeoJsonFeatureCollection
    +getPointLayerCollection(layer: LayerKey, focus: RadiusFilter): PointLayerCollection
  }
  class DemographicsRepository <<repository>> {
    +getAreaDemographics(planningAreaId: string): AreaDemographics
  }
  class FeedbackRepository <<repository>> {
    +saveExplanationFeedback(input: ExplanationFeedbackInput): ExplanationFeedback
    +listExplanationFeedback(profileId: string, page: string): List<ExplanationFeedback>
  }
}

package "Container Classes" {
  class ProfileCatalog <<container>> {
    +profiles: List<BusinessProfile>
    +getActiveProfile(): BusinessProfile
    +findProfileById(profileId: string): BusinessProfile
  }
  class CandidateSiteCollection <<container>> {
    +sites: List<CandidateSite>
    +addSite(site: CandidateSite): void
    +removeSite(siteId: string): void
    +sortByComposite(): List<CandidateSite>
  }
  class ComparisonSet <<container>> {
    +selected: List<CandidateSite>
    +setSelectedSites(siteIds: List<string>): void
    +getSelectedSites(): List<CandidateSite>
    +clear(): void
  }
}

AppStartup --> AuthController
AppStartup --> ProfileController
AppStartup --> MapController

AuthUI --> AuthController
ProfilesUI --> ProfileController
MapUI --> MapController
MapUI --> ScoringController
MapUI --> ExplanationController
MapUI --> ChatbotController
PortfolioUI --> PortfolioController
CompareUI --> CompareController
AdminUI --> AdminController

ProfileController --> ProfileRepository
ProfileController --> UserRepository
MapController --> PlanningAreaRepository
MapController --> DemographicsRepository
MapController --> ScoreRepository
ScoringController --> ScoreEngine
ScoringController --> ScoreRepository
PortfolioController --> SiteRepository
PortfolioController --> ScoreRepository
CompareController --> SiteRepository
AdminController --> ETLCoordinator
AdminController --> PlanningAreaRepository
AdminController --> DemographicsRepository
ExplanationController --> FeedbackRepository
ChatbotController --> FeedbackRepository

User "1" -- "0..*" BusinessProfile : owns
User "1" -- "0..*" CandidateSite : saves
BusinessProfile "1" -- "0..*" CandidateSite : contains
CandidateSite "0..*" -- "0..1" SiteScore : snapshot
PlanningArea "1" -- "0..*" CandidateSite : contains
PlanningArea "1" -- "0..*" AreaDemographics : has
BusinessProfile "1" -- "0..*" WeightConfig : presets
SiteScore "1" -- "0..*" ExplanationFeedback : ratedBy

ProfileCatalog o-- BusinessProfile
CandidateSiteCollection o-- CandidateSite
ComparisonSet o-- CandidateSite

note bottom
Patterns used:
- MVC/BCE separation (Boundary, Control, Entity)
- Repository pattern for persistence access
- Strategy-like scoring via ScoreEngine + WeightConfig
This is the primary Lab 3 design class diagram.
end note

@enduml