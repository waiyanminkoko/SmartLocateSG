@startuml
left to right direction
!theme plain
skinparam backgroundColor #FEFEFE
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontSize 11
}

title UC-20: Compare Candidate Sites

actor "User\n(A01/A02/A03)" as USER
actor "System Backend\n(A04)" as A04

rectangle "SmartLocateSG" {
  usecase "UC-20 Compare Candidate Sites" as UC20
  usecase "UC-17 View Portfolio" as R17
}

USER --> UC20
A04 --> UC20

UC20 ..> R17 : <<include>>

note right of UC20
Pre: Refer corresponding sequence precondition.
Flow: Main interaction follows sequence messages.
AC/EX: Alternate and exception branches traced from sequence.
end note

@enduml
