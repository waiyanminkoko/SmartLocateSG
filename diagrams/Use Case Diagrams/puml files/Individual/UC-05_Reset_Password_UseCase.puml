@startuml UC_05_Individual
left to right direction
!theme plain
skinparam backgroundColor #FEFEFE
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontSize 11
}

title UC-05: Reset Password

actor "User\n(A01/A02/A03)" as USER
actor "System Backend\n(A04)" as A04

rectangle "SmartLocateSG" {
  usecase "UC-05 Reset Password" as UC05
  usecase "UC-03 Log In" as R03
}

USER --> UC05
A04 --> UC05

UC05 ..> R03 : <<include>>

note right of UC05
Pre: Refer corresponding sequence precondition.
Flow: Main interaction follows sequence messages.
AC/EX: Alternate and exception branches traced from sequence.
end note

@enduml
